<Window x:Class="GOVI_FACTURA.BuscarClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Buscar Cliente"
        Height="450"
        Width="700"
        WindowStartupLocation="CenterScreen" Icon="/buscar_cte.png"
        Background="#E0E0E0">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ETIQUETA -->
        <TextBlock Text="Búsqueda por Numero, Nombre o RFC"
                   FontSize="14"
                   Foreground="#333"
                   Margin="5,0,0,5"
                   FontWeight="SemiBold"/>

        <!-- BUSCADOR -->
        <Border Grid.Row="1"
                Background="#F0F0F0"
                CornerRadius="8"
                Padding="6"
                Margin="0,0,0,10"
                BorderBrush="#CCC"
                BorderThickness="1">

            <TextBox x:Name="txtBuscar"
                     Height="30"
                     FontSize="14"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="#000"
                     KeyUp="TxtBuscar_KeyUp"/>
        </Border>

        <!-- GRID -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="5"
                BorderBrush="#CCC"
                BorderThickness="1">

            <DataGrid x:Name="dgClientes"
          AutoGenerateColumns="False"
          MouseDoubleClick="dgClientes_MouseDoubleClick"
          Background="White"
          Foreground="#333"
          RowHeight="34"
          FontSize="14"
          BorderThickness="0"
          GridLinesVisibility="None"
          HeadersVisibility="Column"
          SelectionMode="Single">

                <!-- 🔥 ESTILOS -->
                <DataGrid.Resources>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="#333"/>

                        <Style.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE5B4"/>
                            </Trigger>

                            <!-- Seleccion -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FAA219"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>

                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <!-- 🔥 CELDAS (quita azul feo) -->
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FAA219"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <!-- 🔥 COLUMNAS -->
                <DataGrid.Columns>
                    <DataGridTextColumn Header="# Cliente" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="RFC" Binding="{Binding RFC}" Width="150"/>
                </DataGrid.Columns>

            </DataGrid>
        </Border>

        <!-- BOTON -->
        <Button Content="Seleccionar"
                Grid.Row="3"
                Height="35"
                Margin="0,10,0,0"
                Background="#FAA219"
                Foreground="Black"
                FontWeight="SemiBold"
                BorderThickness="0"
                Click="BtnSeleccionar_Click"/>

    </Grid>
</Window>
<Window x:Class="GOVI_FACTURA.ComprasFiliales"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Title="Compras Filiales"
        Height="800"
        Width="1500"
        Background="Black">
    <Window.Resources>

        <!-- 🎨 Colores principales -->
        <SolidColorBrush x:Key="ColorFondoNegro" Color="#0B0B0B"/>
        <SolidColorBrush x:Key="ColorGrisOscuro" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="ColorGrisMedio" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="ColorGrisClaro" Color="#3A3A3A"/>

        <SolidColorBrush x:Key="ColorAmarillo" Color="#FFC107"/>
        <SolidColorBrush x:Key="ColorAmarilloHover" Color="#FFD54F"/>

        <SolidColorBrush x:Key="ColorTextoBlanco" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ColorTextoGris" Color="#BDBDBD"/>
        <SolidColorBrush x:Key="ColorTextoNegro" Color="Black"/>


        <!-- Textos -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBlanco}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CaretBrush" Value="{StaticResource ColorAmarillo}"/>

            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>
            </Style.Triggers>
        </Style>


        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>

                <!-- Focus -->
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>

            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Padding" Value="8,5"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2C2C2C"/>
                </Trigger>

                <!-- Seleccionado -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>

            </Style.Triggers>
        </Style>


        <!-- DatePicker -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBlanco}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
        </Style>

        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBlanco}"/>
            <Setter Property="Background" Value="{StaticResource ColorFondoNegro}"/>
        </Style>


        <!-- Botones -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="25"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}"
                        BorderBrush="#E0A800"
                        BorderThickness="1">

                            <!-- 🔥 SOMBRA -->
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                          BlurRadius="8"
                                          ShadowDepth="2"
                                          Opacity="0.5"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- 🔥 HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFC107"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FFD54F"/>
                            </Trigger>

                            <!-- 🔥 CLICK -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF8F00"/>
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- 🔥 DISABLED -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0D0D0D"/>
            <!-- fondo general -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>

            <!-- Filas -->
            <Setter Property="RowBackground" Value="#121212"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A1A"/>

            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource ColorGrisMedio}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="30"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ColorGrisMedio}"/>
                </Trigger>

                <!-- Selección -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A2A00"/>
                    <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>

            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

    </Window.Resources>
    
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- BOTONES -->
            <RowDefinition Height="Auto"/>
            <!-- FORM -->
            <RowDefinition Height="*"/>
            <!-- GRID -->
            <RowDefinition Height="Auto"/>
            <!-- TOTALES -->
        </Grid.RowDefinitions>

        <!-- ===================== BOTONES ===================== -->
        <Border Grid.Row="0"
        Background="#1E1E1E"
        BorderBrush="#FAA219"
        BorderThickness="2"
        CornerRadius="8"
        Padding="10"
        Margin="0,0,0,15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- IZQUIERDA: Fecha -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Fecha" Foreground="#EAE6DD"/>
                    <TextBox x:Name="txtFecha"/>
                </StackPanel>

                <!-- CENTRO: ComboBox -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">

                    <StackPanel Margin="10,0">
                        <TextBlock Text="Proveedor" Foreground="#EAE6DD"/>
                        <ComboBox x:Name="cmbProveedor" Width="250"/>
                    </StackPanel>

                    <StackPanel Margin="10,0">
                        <TextBlock Text="Cedis / Sucursal" Foreground="#EAE6DD"/>
                        <ComboBox x:Name="cmbCedis" Width="250"/>
                    </StackPanel>

                </StackPanel>

                <!-- DERECHA: RadioButtons -->
                <StackPanel Grid.Column="2"
            Orientation="Horizontal"
            HorizontalAlignment="Right">

                    <RadioButton x:Name="rbSAP"
                     Content="SAP Business One"
                     GroupName="Modo"
                     IsChecked="True"
                     Checked="Modo_Checked"/>
                    
                    <RadioButton x:Name="rbAutomotive"
                 Content="Automotive"
                 GroupName="Modo"
                 Foreground="#FFC107"
                 Margin="5"
                 Checked="Modo_Checked"/>

                    <RadioButton x:Name="rbSucursales"
                 Content="Sucursales"
                 GroupName="Modo"
                 Foreground="#FFC107"
                 Margin="5"
                 Checked="Modo_Checked"/>

                </StackPanel>
            </Grid>
        </Border>
        <!-- ===================== FORM ===================== -->
        <Border Grid.Row="1"
        Background="#1E1E1E"
        BorderBrush="#FAA219"
        BorderThickness="2"
        CornerRadius="8"
        Padding="15"
        Margin="0,0,0,15">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- FILA 1 -->
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Tipo Documento"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="rbFactura" Content="Factura" Foreground="#EAE6DD"/>
                        <RadioButton x:Name="rbRemision" Content="Remisión" Foreground="#EAE6DD"/>
                    </StackPanel>
                </StackPanel>

                <!-- FILA 2 -->
                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="Orden Compra"/>
                    <TextBox x:Name="txtOrdenCompra"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="Factura"/>
                    <TextBox x:Name="txtFactura"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="Cliente"/>
                    <TextBox x:Name="txtCliente"/>
                </StackPanel>

                <!-- BOTÓN BUSCAR ABAJO -->
                <StackPanel Grid.Row="1" Grid.Column="3" VerticalAlignment="Bottom">
                    <Button x:Name="btnBuscar" Content="Buscar" Click="btnBuscar_Click"/>
                </StackPanel>

            </Grid>
        </Border>
        <!-- ===================== DATAGRID ===================== -->
        <Border Grid.Row="2"
                Background="#1E1E1E"
                BorderBrush="#FAA219"
                BorderThickness="2"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,15">

            <DataGrid x:Name="dgProductos"
                      AutoGenerateColumns="False"
                      CanUserAddRows="True">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" />
                    <DataGridTextColumn Header="Marca" Binding="{Binding Marca}" Width="120"/>
                    <DataGridTextColumn Header="Desc Marca" Binding="{Binding DescuentoMarca}" Width="120"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="100"/>
                    <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120"/>
                    <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento}" Width="120"/>
                    <DataGridTextColumn Header="Total s/Desc" Binding="{Binding TotalSinDescuento}" Width="140"/>
                    <DataGridTextColumn Header="Impuesto" Binding="{Binding Impuesto}" Width="120"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

        <!-- ===================== TOTALES ===================== -->
        <Grid Grid.Row="3">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- BOTONES -->
            <StackPanel Orientation="Horizontal">

                <Button x:Name="btnGrabar" Content="Grabar" Click="btnGrabar_Click"/>
                <Button x:Name="btnActivar" Content="Activar"/>
                <Button x:Name="btnReimpresion" Content="Reimpresión"/>
                
            </StackPanel>

            <!-- TOTALES -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">

                <TextBlock Text="SubTotal:" Margin="5"/>
                <TextBox x:Name="txtSubTotal" Width="100"/>

                <TextBlock Text="Descuento:" Margin="5"/>
                <TextBox x:Name="txtDescuento" Width="100"/>
                
                <TextBlock Text="SUB TOTAL:" Margin="5"/>
                <TextBox x:Name="txtSubTotalSinDesc" Width="100"/>

                <TextBlock Text="IVA:" Margin="5"/>
                <TextBox x:Name="txtIVA" Width="100"/>

                <TextBlock Text="Retención:" Margin="5"/>
                <TextBox Width="100"/>

                <TextBlock Text="Importe Neto:" Margin="5"/>
                <TextBox x:Name="txtTotal" Width="120"/>
            </StackPanel>

        </Grid>

    </Grid>
</Window>
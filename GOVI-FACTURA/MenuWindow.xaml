<Window x:Class="GOVI_FACTURA.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GOVI_FACTURA"
        mc:Ignorable="d"
        Title="MenuWindow" Height="450" Width="800"
        WindowStartupLocation="CenterScreen" Icon="/logo-chico.png"
        WindowState="Maximized">
    <Grid>

        <Grid.Background>
            <ImageBrush ImageSource="/fondo.png"
                    Stretch="UniformToFill"
                    Opacity="0.80"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= MENU SUPERIOR ================= -->
        <Menu Background="#1A1A1A" Foreground="White">

            <MenuItem Header="Archivo">
                <MenuItem Header="Salir" Click="Salir_Click" Foreground="#faa219"/>
            </MenuItem>

            <MenuItem Header="Ventas">
                <MenuItem Header="Facturación" Foreground="#faa219" Click="BtnFacturacion_Click"/>
            </MenuItem>

            <MenuItem Header="Compras">
                <MenuItem Header="Compras" Foreground="#faa219"/>
            </MenuItem>

            <MenuItem Header="Reportes">
                <MenuItem Header="Ventas" Foreground="#faa219" />
            </MenuItem>

            <MenuItem Header="Configuración">
                <MenuItem Header="Usuarios" Foreground="#faa219"/>
            </MenuItem>

        </Menu>

        <!-- ================= CONTENIDO ================= -->
        <Grid Grid.Row="1">

            <!-- SUBFORM -->
            <ContentControl x:Name="contenedor"/>

            <!-- BOTONES CENTRALES -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="GOVI ERP 2026"
                       Foreground="#FAA219"
                       FontSize="26"
                       Margin="0,0,0,30"
                       HorizontalAlignment="Center"/>

                <Button Content="Facturación"
                    Width="220"
                    Height="50"
                    Margin="10"
                    Background="#FAA219"
                    Click="BtnFacturacion_Click"/>

                <Button Content="Compras"
                    Width="220"
                    Height="50"
                    Margin="10" 
                    Background="#FAA219"
                    Click="BtnCompras_Click"/>

                <Button Content="Configuración"
                    Width="220"
                    Height="50"
                    Margin="10"/>

            </StackPanel>

        </Grid>

    </Grid>
</Window>

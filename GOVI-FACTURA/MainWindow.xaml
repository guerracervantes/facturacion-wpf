<Window x:Class="GOVI_FACTURA.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GOVI Facturación"
        Height="800"
        Width="1150"
        Background="#0D0D0D"
         WindowStartupLocation="CenterScreen" Icon="/logo-chico.png">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- BUSQUEDA -->
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Cliente:" Foreground="Gray" Margin="5" FontSize="14" VerticalAlignment="Center"/>

                <TextBox x:Name="txtCliente"
                         Width="100"
                         Height="32"
                         FontSize="14"
                         FontWeight="Bold"
                         Margin="5"
                         VerticalContentAlignment="Center"
                         KeyDown="txtCliente_KeyDown"/>

                <Button Width="100"
        Height="32"
        Margin="5"
        Background="#FAA219"
        Click="BtnBuscarCliente_Click">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <Image Source="/buscar_cte.png"
               Width="16"
               Height="16"
               Margin="0,0,5,0"/>

                        <TextBlock Text="Buscar"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"/>

                    </StackPanel>

                </Button>
            </StackPanel>

            <!-- TIPOS -->
            <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="10" Padding="10">
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="MSI:" Foreground="Gray" FontSize="14"/>
                    <TextBlock x:Name="lblMSI" Grid.Column="1" Foreground="#FAA219" FontSize="14"/>

                    <TextBlock Text="CDO2:" Grid.Row="1" Foreground="Gray" FontSize="14"/>
                    <TextBlock x:Name="lblCDO2" Grid.Row="1" Grid.Column="1" Foreground="#FAA219" FontSize="14"/>

                    <TextBlock Text="Confort:" Grid.Row="2" Foreground="Gray" FontSize="14"/>
                    <TextBlock x:Name="lblConfort" Grid.Row="2" Grid.Column="1" Foreground="#FAA219" FontSize="14"/>

                    <TextBlock Text="Buen Fin:" Grid.Row="3" Foreground="Gray" FontSize="14"/>
                    <TextBlock x:Name="lblBuenFin" Grid.Row="3" Grid.Column="1" Foreground="#FAA219" FontSize="14"/>
                </Grid>
            </Border>

            <!-- FOLIO -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <TextBlock Text="Folio" Foreground="Gray" FontSize="13"/>
                <TextBlock x:Name="lblFolio" Foreground="#FAA219" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Fecha" Foreground="Gray" FontSize="13"/>
                <TextBlock x:Name="lblFecha" Foreground="White" FontSize="14"/>
            </StackPanel>

        </Grid>

        <!-- CLIENTE -->
        <TabControl Grid.Row="1" Margin="5" Background="#1A1A1A">
            <TabControl.Resources>

            <!-- ESTILO DE TABS -->
            <Style TargetType="TabItem">
                <Setter Property="Margin" Value="5,0,5,0"/>
                <Setter Property="Padding" Value="15,5"/>
                <Setter Property="Background" Value="#2A2A2A"/>
                <Setter Property="Foreground" Value="White"/>

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8,8,0,0"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}">

                                <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"/>

                            </Border>

                            <ControlTemplate.Triggers>

                                <!-- ACTIVO -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FAA219"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>

                                <!-- HOVER -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#FFB84D"/>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            </TabControl.Resources>

            <!-- ========================= -->
            <!-- TAB 1: CLIENTE (TU DISEÑO) -->
            <!-- ========================= -->
            <TabItem Header="Cliente">

                <Border Background="#1A1A1A" CornerRadius="10" Padding="12">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- FILA 1 -->
                        <TextBlock Text="Nombre:" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblClienteNombre" Grid.Column="1" Foreground="White" FontSize="18"/>

                        <TextBlock Text="RFC:" Grid.Column="2" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblClienteRFC" Grid.Column="3" Foreground="White" FontSize="14"/>

                        <!-- FILA 2 -->
                        <TextBlock Text="Dirección:" Grid.Row="1" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblClienteDireccion"
                           Grid.Row="1"
                           Grid.Column="1"
                           Grid.ColumnSpan="3"
                           Foreground="White"
                           TextWrapping="Wrap"
                           FontSize="14"/>

                        <TextBlock Text="Ciudad:" Grid.Row="1" Grid.Column="2" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblCiudad" Grid.Row="1" Grid.Column="3" Foreground="White" FontSize="14"/>

                        <!-- FILA 3 -->
                        <TextBlock Text="Estado:" Grid.Row="2" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblEstado" Grid.Row="2" Grid.Column="1" Foreground="White" FontSize="14"/>

                        <TextBlock Text="Teléfono:" Grid.Row="2" Grid.Column="2" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblTelefono" Grid.Row="2" Grid.Column="3" Foreground="White" FontSize="14"/>

                        <!-- FILA 4 -->
                        <TextBlock Text="Condición:" Grid.Row="3" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblCondicion" Grid.Row="3" Grid.Column="1" Foreground="#FAA219" FontSize="14"/>

                        <TextBlock Text="Tipo Venta:" Grid.Row="3" Grid.Column="2" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblTipoVenta" Grid.Row="3" Grid.Column="3" Foreground="#FAA219" FontSize="14"/>

                        <!-- FILA 5 -->
                        <TextBlock Text="Saldo:" Grid.Row="4" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblSaldo" Grid.Row="4" Grid.Column="1" Foreground="#FF4C4C" FontSize="14"/>

                        <TextBlock Text="Límite:" Grid.Row="4" Grid.Column="2" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblLimite" Grid.Row="4" Grid.Column="3" Foreground="#00FF00" FontSize="14"/>

                    </Grid>

                </Border>

            </TabItem>

            <!-- ========================= -->
            <!-- TAB 2: Datos Comerciales -->
            <!-- ========================= -->
            <TabItem Header="Datos Comerciales">

                <Border Background="#1A1A1A" Padding="12">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- 🔹 USO CFDI -->
                        <TextBlock Text="Uso CFDI:" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblUsoCFDI"
                       Grid.Column="1"
                       Foreground="White" FontSize="14" />

                       <!-- <TextBlock x:Name="lblUsoCFDI2"
                       Grid.Column="2"
                       Grid.ColumnSpan="2"
                       Foreground="White"/>-->
                        <TextBlock Text="Régimen Fiscal:" Grid.Row="1" Foreground="Gray" FontSize="14"/>

                        <TextBlock x:Name="lblRegimenFiscal"
                       Grid.Row="1"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Foreground="White" FontSize="14"/>         

                        <!-- 🔹 VENDEDOR -->
                        <TextBlock Text="Vendedor:" Grid.Row="2" Foreground="Gray" FontSize="14"/>

                        <StackPanel Grid.Row="2"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                            <TextBlock x:Name="lblVendedorId"
                           Foreground="White"
                           Margin="0,0,10,0" FontSize="14"/>

                            <TextBlock x:Name="lblVendedorNombre"
                           Foreground="White" FontSize="14"/>

                        </StackPanel>

                        <!-- 🔹 RAZON SOCIAL -->
                        <TextBlock Text="Razón Social:" Grid.Row="3" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblRazonSocial"
                       Grid.Row="3"
                       Grid.Column="1"
                       Grid.ColumnSpan="3"
                       Foreground="White"
                       TextWrapping="Wrap" FontSize="14"/>

                        <!-- 🔹 CONSIGNADO -->
                        <TextBlock Text="Consignado:" Grid.Row="4" Foreground="Gray" FontSize="14" />

                        <StackPanel Grid.Row="4"
                        Grid.Column="1"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal">

                            <TextBlock x:Name="lblConsignado1"
                           Foreground="White"
                           Margin="0,0,10,0" FontSize="14"/>

                            <TextBlock x:Name="lblConsignado2"
                           Foreground="White" FontSize="14"/>

                        </StackPanel>

                    </Grid>

                </Border>

            </TabItem>
            <!-- ========================= -->
            <!-- TAB 3: Promociones -->
            <!-- ========================= -->
            <TabItem Header="Programa de Lealtad y Monedero Electronico ">

                <Border Background="#1A1A1A" Padding="12">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!-- 🔹 tarjeta -->
                        <TextBlock Text="Tarjeta (GOVI PREMIOS ):" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblTarjeta"
             Grid.Column="1"
             Foreground="White" FontSize="14" />

                        
                        <TextBlock Text="Monedero Electronico" Grid.Row="1" Foreground="Gray" FontSize="14"/>
                        <TextBlock x:Name="lblSaldoMonedero"
             Grid.Row="1"
             Grid.Column="1"
             Grid.ColumnSpan="3"
             Foreground="White" FontSize="14"/>

                        <!-- 🔹 saldo disponible -->
                        <TextBlock Text="Saldo Disponible:" Grid.Row="2" Foreground="Gray" FontSize="14"/>

                        <StackPanel Grid.Row="2"
              Grid.Column="1"
              Grid.ColumnSpan="3"
              Orientation="Horizontal"
              VerticalAlignment="Center">

                            <TextBlock x:Name="lblSaldoDisponible"
                 Foreground="White"
                 Margin="0,0,10,0" FontSize="14"/>

                          

                        </StackPanel>

                        
                       

                    </Grid>

                </Border>

            </TabItem>

        </TabControl>

        <!-- PRODUCTOS -->
        <Grid Grid.Row="2" Margin="5">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 🔹 CAPTURA -->
            <Border Background="#1A1A1A" CornerRadius="10" Padding="10" Margin="0,0,0,5">
                <StackPanel Orientation="Horizontal">

                    <TextBlock Text="Código:" Foreground="Gray" Margin="5" FontSize="14"/>

                    <TextBox x:Name="txtCodigoProducto"
                     Width="220"
                     Height="32"
                     FontSize="14"
                     Margin="5"
                     VerticalContentAlignment="Center"
                     KeyDown="txtCodigoProducto_KeyDown"/>

                    <Button Content="Agregar"
                    Width="100"
                    Margin="5"
                    Background="#FAA219"
                    Click="BtnAgregarProducto_Click"/>
                </StackPanel>
            </Border>

            <!-- 🔹 GRID -->
            <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="10" Padding="5">

                <DataGrid x:Name="dgProductos"
              AutoGenerateColumns="False"
              Background="#1A1A1A"
              Foreground="White"
              RowHeight="35"
              FontSize="14"
              GridLinesVisibility="None"
              HeadersVisibility="Column"
              BorderThickness="0">

                    <!-- 🔥 HEADERS -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#2A2A2A"/>
                            <Setter Property="Foreground" Value="#FAA219"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- 🔥 FILAS -->
                    <DataGrid.Resources>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#1A1A1A"/>
                            <Setter Property="Foreground" Value="White"/>

                            <Style.Triggers>

                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>

                                <!-- Seleccion -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FAA219"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <!-- 🔥 CELDAS -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="5"/>

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#FAA219"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <!-- 🔥 COLUMNAS -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="150"/>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="*"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="100"/>
                        <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="120"/>
                        <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="120"/>
                    </DataGrid.Columns>

                </DataGrid>
            </Border>
            <!-- 🔹 TOTALES -->
            <Border Grid.Row="2" Background="#1A1A1A" CornerRadius="10" Padding="10" Margin="0,5,0,0">
                <StackPanel HorizontalAlignment="Right" Width="250">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Subtotal:" Foreground="Gray" Width="120"/>
                        <TextBlock x:Name="lblSubtotal" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="IVA:" Foreground="Gray" Width="120"/>
                        <TextBlock x:Name="lblIVA" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="TOTAL:" Foreground="#FAA219" Width="120"/>
                        <TextBlock x:Name="lblTotal" Foreground="#FAA219" FontSize="18" FontWeight="Bold"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>
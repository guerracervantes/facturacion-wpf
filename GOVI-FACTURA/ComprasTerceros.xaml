<Window x:Class="GOVI_FACTURA.ComprasTerceros"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GOVI_FACTURA"
        mc:Ignorable="d"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Title="Compras Terceros" Height="800" Width="1500"
        Background="Black">

    <!-- 🎨 ESTILOS -->
    <Window.Resources>

        <!-- 🎨 Colores principales -->
        <SolidColorBrush x:Key="ColorFondoNegro" Color="#0B0B0B"/>
        <SolidColorBrush x:Key="ColorGrisOscuro" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="ColorGrisMedio" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="ColorGrisClaro" Color="#3A3A3A"/>

        <SolidColorBrush x:Key="ColorAmarillo" Color="#FFC107"/>
        <SolidColorBrush x:Key="ColorAmarilloHover" Color="#FFD54F"/>

        <SolidColorBrush x:Key="ColorTextoBlanco" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="ColorTextoGris" Color="#BDBDBD"/>
        <SolidColorBrush x:Key="ColorTextoNegro" Color="Black"/>
        
        
        <!-- Textos -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBlanco}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CaretBrush" Value="{StaticResource ColorAmarillo}"/>

            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        
        <!-- ComboBox -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>

                <!-- Focus -->
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>

            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Padding" Value="8,5"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2C2C2C"/>
                </Trigger>

                <!-- Seleccionado -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A3A"/>
                </Trigger>

            </Style.Triggers>
        </Style>
        

        <!-- DatePicker -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBlanco}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
        </Style>
        
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="{StaticResource ColorTextoBlanco}"/>
            <Setter Property="Background" Value="{StaticResource ColorFondoNegro}"/>
        </Style>

        
        <!-- Botones -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinHeight" Value="25"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="8"
                        Padding="{TemplateBinding Padding}"
                        BorderBrush="#E0A800"
                        BorderThickness="1">

                            <!-- 🔥 SOMBRA -->
                            <Border.Effect>
                                <DropShadowEffect Color="Black"
                                          BlurRadius="8"
                                          ShadowDepth="2"
                                          Opacity="0.5"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- 🔥 HOVER -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFC107"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#FFD54F"/>
                            </Trigger>

                            <!-- 🔥 CLICK -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF8F00"/>
                                <Setter TargetName="bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <!-- 🔥 DISABLED -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        
        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#0D0D0D"/>
            <!-- fondo general -->
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>

            <!-- Filas -->
            <Setter Property="RowBackground" Value="#121212"/>
            <Setter Property="AlternatingRowBackground" Value="#1A1A1A"/>

            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
        </Style>
        
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource ColorGrisMedio}"/>
            <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource ColorGrisClaro}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource ColorGrisOscuro}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="30"/>

            <Style.Triggers>

                <!-- Hover -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ColorGrisMedio}"/>
                </Trigger>

                <!-- Selección -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A2A00"/>
                    <Setter Property="Foreground" Value="{StaticResource ColorAmarillo}"/>
                </Trigger>

            </Style.Triggers>
        </Style>
        
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- BOTONES -->
            <RowDefinition Height="Auto"/>
            <!-- FORM -->
            <RowDefinition Height="*"/>
            <!-- GRID -->
            <RowDefinition Height="Auto"/>
            <!-- TOTALES -->
        </Grid.RowDefinitions>
        
        
        <!-- 🔹 BOTONES -->
        <Border x:Name="borderTop" Grid.Row="0"
        Background="{StaticResource ColorGrisOscuro}"
        BorderBrush="#FAA219"
        BorderThickness="2"
        CornerRadius="8"
        Padding="10"
        Margin="0,0,0,15">

            <Grid>

                <!-- 🔘 MODO (RadioButtons a la izquierda) -->
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">

                    <RadioButton Content="🔎 Búsqueda"
                         GroupName="Modo"
                         Foreground="#EAE6DD"
                         Margin="0,0,15,0"
                         IsChecked="True"
                         Checked="ModoBusqueda_Checked"/>

                    <RadioButton Content="💾 Captura"
                         GroupName="Modo"
                         Foreground="#EAE6DD"
                         Checked="ModoCaptura_Checked"/>

                </StackPanel>
                <!-- 🔹 CHECKBOX CENTRO -->
                <StackPanel x:Name="panelBusquedaOpciones"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed">

                    <CheckBox x:Name="chkImpresion"
              Content="Impresión"
              Foreground="White"
              Margin="0,0,20,0"/>

                    <CheckBox x:Name="chkBusquedaFecha"
              Content="Búsqueda por fecha"
              Foreground="White"
              Checked="chkBusquedaFecha_Checked"
              Unchecked="chkBusquedaFecha_Unchecked"/>

                </StackPanel>
                <!-- 🔘 BOTONES (a la derecha) -->
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">

                    <Button x:Name="btnBusqueda"
                    Content="Búsqueda"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="btnBusqueda_Click"/>

                    <Button x:Name="btnCalcular"
                    Content="Calcular"
                    Width="100"
                    Margin="10,0,10,0"
                    Click="btnCalcular_Click"/>

                    <Button x:Name="btnGuardar"
                    Content="Guardar"
                    Width="100"
                    Margin="10,0,10,0"
                    Click="btnGuardar_Click"/>

                </StackPanel>

            </Grid>

        </Border>

        
        <!-- 🔹 FORMULARIO SUPERIOR -->
        <Border x:Name="borderMiddleTop" Grid.Row="1"
        BorderBrush="#FAA219"
        BorderThickness="2"
        CornerRadius="8"
        Padding="15"
        Margin="0,0,0,15"
        Background="{StaticResource ColorGrisOscuro}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- FILA 1 -->
                
                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Proveedor"/>
                    <ComboBox x:Name="cmbProveedor"
                              DropDownOpened="cmbProveedor_DropDownOpened"
                              SelectionChanged="cmbProveedor_SelectionChanged"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              DisplayMemberPath="Nombre"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1"> 
                    <TextBlock Text="No. Proveedor"/>
                    <TextBox x:Name="txtProveedorId" TextChanged="txtProveedorId_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2">
                    <TextBlock Text="Fecha"/>
                    <TextBox x:Name="txtFecha" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel x:Name="panelDescuento" Grid.Row="0" Grid.Column="3">
                    <TextBlock Text="Descuento (%)"/>
                    <ComboBox x:Name="cmbDescuento" SelectionChanged="cmbDescuento_SelectionChanged"/>
                </StackPanel>
                
                <StackPanel x:Name="panelFechaInicio" Grid.Row="0" Grid.Column="3" Visibility="Collapsed">
                    <TextBlock Text="Fecha Inicio"/>
                    <DatePicker x:Name="dpFechaInicio"/>
                </StackPanel>
                
                <!-- FILA 2 -->

                <StackPanel Grid.Row="1" Grid.Column="0">
                    <TextBlock Text="F. Orden"/>
                    <TextBox x:Name="txtFactura" TextChanged="txtFactura_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="Autorización"/>
                    <TextBox x:Name="txtAutorizacion"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2">
                    <TextBlock Text="Fecha Llegada"/>
                    <TextBox x:Name="txtFechaLlegada" IsReadOnly="True"/>
                </StackPanel>

                <StackPanel x:Name="panelIVA" Grid.Row="1" Grid.Column="3">
                    <TextBlock Text="IVA (%)"/>
                    <ComboBox x:Name="cmbIVA" SelectionChanged="cmbIVA_SelectionChanged"/>
                </StackPanel>
                
                <StackPanel x:Name="panelFechaFin" Grid.Row="1" Grid.Column="3" Visibility="Collapsed">
                    <TextBlock Text="Fecha Fin"/>
                    <DatePicker x:Name="dpFechaFin"/>
                </StackPanel>
                
            </Grid>
        </Border>
        
        
        <!-- 🔹 SECCIÓN DETALLE -->
        <Border x:Name="borderMiddleLow" Grid.Row="2"
        BorderBrush="#FAA219"
        BorderThickness="2"
        CornerRadius="8"
        Padding="10"
        Margin="0,0,0,15"
        Background="{StaticResource ColorGrisOscuro}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 🔹 DATA GRID -->
                <DataGrid x:Name="dgDetalle" Grid.Row="0"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          ItemsSource="{Binding Detalles}"
                          SelectionChanged="dgDetalle_SelectionChanged"
                          RowEditEnding="dgDetalle_RowEditEnding"
                          CellEditEnding="dgDetalle_CellEditEnding"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          PreviewKeyDown="dgDetalle_PreviewKeyDown"
                          KeyboardNavigation.TabNavigation="None">
                    

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Producto" Binding="{Binding Producto}" Width="100"/>
                        <DataGridTextColumn Header="Código Proveedor" Binding="{Binding CodigoProveedor}" Width="120"/>
                        <DataGridTemplateColumn Header="Marca" Width="150">

                            <!-- 🔹 MODO NORMAL (NO EDITANDO) -->
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Marca}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                            <!-- 🔹 MODO EDICIÓN (COMBO) -->
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox
                ItemsSource="{Binding MarcasDisponibles}"
                DisplayMemberPath="strDescripcion"
                SelectedValuePath="iMarcaId"
                SelectedValue="{Binding Marca, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                IsEditable="False"
            />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>

                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Descripción" Binding="{Binding Descripcion}" Width="200"/>
                        <DataGridCheckBoxColumn Header="Serv" Binding="{Binding Servicio}" Width="60"/>
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="80"/>
                        <DataGridTextColumn Header="Costo" Binding="{Binding Costo}" Width="80"/>
                        <DataGridTextColumn Header="Precio Anterior" Binding="{Binding PrecioAnterior}" Width="120"/>
                        <DataGridTextColumn Header="Precio Nuevo" Binding="{Binding PrecioNuevo}" Width="120"/>
                        <DataGridTextColumn Header="Importe" Binding="{Binding Importe}" Width="100"/>
                        <DataGridTextColumn Header="Localización" Binding="{Binding Localizacion}" Width="120"/>
                        <DataGridTextColumn Header="Venta" Binding="{Binding Venta}" Width="60"/>
                        <DataGridTextColumn Header="Descuento" Binding="{Binding Descuento}" Width="100"/>
                        <DataGridTextColumn Header="Subtotal S/Desc" Binding="{Binding SubTotalSinDescuento}" Width="140"/>
                        <DataGridTextColumn Header="Impuesto" Binding="{Binding Impuesto}" Width="100"/>
                        <DataGridTextColumn Header="Retención" Binding="{Binding Retencion}" Width="100"/>
                        <DataGridTemplateColumn x:Name="colEliminar" Header="Eliminar" Width="80" IsReadOnly="True">
                            <DataGridTemplateColumn.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="IsTabStop" Value="False"/>
                                </Style>
                            </DataGridTemplateColumn.CellStyle>

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X"
                    Background="Red"
                    Foreground="White"
                    Padding="5"
                    Focusable="False"
                    IsTabStop="False"
                    Click="BtnEliminarFila_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        
        
        <!-- 🔹 TOTALES -->
        <Grid x:Name="gridOMPanel" Grid.Row="3" Margin="0,10,0,0">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            <!-- 🔥 PANEL OM -->
            <Border x:Name="borderLow1" Grid.Column="0"
            BorderBrush="#FAA219"
            BorderThickness="2"
            CornerRadius="8"
            Padding="10"
            Margin="5"
            Background="{StaticResource ColorGrisOscuro}">

                <StackPanel>

                    <!-- DATAGRID OM -->
                    <Grid>
                        <DataGrid x:Name="dgOM"
          AutoGenerateColumns="False"
          CanUserAddRows="True"
          ItemsSource="{Binding Productos}"
          ColumnWidth="*"
          HorizontalScrollBarVisibility="Auto"
          HeadersVisibility="Column"
          PreviewKeyDown="dgOM_PreviewKeyDown"
          SelectionChanged="dgOM_SelectionChanged">

                            <DataGrid.Columns>

                                <!-- PRODUCTO -->
                                <DataGridTextColumn Header="Producto"
                            Width="2*"
                            Binding="{Binding Producto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                <!-- DESCRIPCIÓN -->
                                <DataGridTextColumn Header="Descripción"
                            Width="3*"
                            Binding="{Binding Descripcion, Mode=TwoWay}" />

                                <!-- MARCA -->
                                <DataGridTextColumn Header="Marca"
                            Width="*"
                            Binding="{Binding Marca, Mode=TwoWay}" IsReadOnly="True"/>

                                <!-- PRECIO -->
                                <DataGridTextColumn Header="Precio"
                            Width="*"
                            Binding="{Binding Precio, Mode=TwoWay, StringFormat=N2}" IsReadOnly="True"/>

                                <!-- ACCIONES -->
                                <DataGridTemplateColumn Header="Acción" Width="2*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                                                <!-- AGREGAR -->
                                                <Button Content="Agregar"
                                Background="#4CAF50"
                                Foreground="White"
                                Padding="5"
                                Margin="2"
                                Click="AgregarFila_Click"/>

                                                <!-- ELIMINAR -->
                                                <Button Content="Eliminar"
                                Background="#E53935"
                                Foreground="White"
                                Padding="5"
                                Margin="2"
                                Click="EliminarFila_Click"/>

                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </StackPanel>

            </Border>
            <!-- 🔥 COLUMNA 1: COMBOS -->
            <Border x:Name="borderLow2" Grid.Column="1"
            BorderBrush="#FAA219"
            BorderThickness="2"
            CornerRadius="8"
            Padding="10"
            Margin="5"
            Background="{StaticResource ColorGrisOscuro}">

                <StackPanel x:Name="panelOMConfig">

                    <TextBlock Text="Configuración"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>


                    <!-- UNIDAD -->
                    <TextBlock Text="Unidad"/>
                    <ComboBox x:Name="cmbUnidadOM"
                              ItemsSource="{Binding DataContext.Unidades, RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Descripcion"
                              SelectedValuePath="Id"
                              SelectionChanged="cmbUnidadOM_SelectionChanged"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              IsTextSearchCaseSensitive="False"/>
                    <!-- FAMILIA -->
                    <TextBlock Text="Familia"/>
                    <ComboBox x:Name="cmbFamiliaOM"
                              ItemsSource="{Binding DataContext.Familias, RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Descripcion"
                              SelectedValuePath="Id"
                              SelectionChanged="cmbFamiliaOM_SelectionChanged"
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              IsTextSearchCaseSensitive="False"/>
                    <!-- GRUPO -->
                    <TextBlock Text="Grupo"/>

                    <ComboBox x:Name="cmbGrupoOM"
                              ItemsSource="{Binding DataContext.Grupos, RelativeSource={RelativeSource AncestorType=Window}}"
                              DisplayMemberPath="Descripcion"
                              SelectedValuePath="Id"
                              SelectionChanged="cmbGrupoOM_SelectionChanged" 
                              IsEditable="True"
                              IsTextSearchEnabled="True"
                              StaysOpenOnEdit="True"
                              IsTextSearchCaseSensitive="False"/>
                </StackPanel>
            </Border>

            <Border x:Name="borderLow3" Grid.Column="2"
            BorderBrush="#FAA219"
            BorderThickness="2"
            CornerRadius="8"
            Padding="10"
            Margin="5"
            Background="{StaticResource ColorGrisOscuro}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Sub Total:" Width="120"/>
                        <TextBox x:Name="txtSubTotal" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Descuento:" Width="120"/>
                        <TextBox x:Name="txtDescuento" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="SUBTOTAL:" Width="120"/>
                        <TextBox x:Name="txtSubTotalFinal" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="IVA:" Width="120"/>
                        <TextBox x:Name="txtIVAImporte" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RETENCIÓN:" Width="120"/>
                        <TextBox x:Name="txtRetencion" IsReadOnly="True"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total:" Width="120"/>
                        <TextBox x:Name="txtTotal" IsReadOnly="True"/>
                    </StackPanel>

                </StackPanel>
            </Border>

        </Grid>

    </Grid>
</Window>